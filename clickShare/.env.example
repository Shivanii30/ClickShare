SECRET_KEY=replace-me-with-a-secure-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TIME_ZONE=UTC

DATABASE_URL=postgresql://username:password@hostname:5432/database_name

SUPABASE_URL=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=replace-me

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-me@example.com
EMAIL_HOST_PASSWORD=replace-me

MAX_UPLOAD_FILES=5
MAX_UPLOAD_FILE_SIZE_MB=5
MAX_TOTAL_UPLOAD_SIZE_MB=9
DRF_ANON_THROTTLE_RATE=30/hour
DRF_USER_THROTTLE_RATE=120/hour
LOG_LEVEL=INFO
